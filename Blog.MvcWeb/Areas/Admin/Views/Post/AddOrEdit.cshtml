@{
    Layout = "~/Views/Shared/_AdminFormLayout.cshtml";
}

@section Head {
    <style>

    </style>
}

<form class="layui-form" action="#" id="addOrEditForm" lay-filter="addOrEditForm">
  <div class="layui-form-item">
        <label class="layui-form-label">文章标题</label>
        <div class="layui-input-block">
            <input type="text" name="title" required lay-verify="required" placeholder="请输入标题" autocomplete="off" class="layui-input">
        </div>
        <label class="layui-form-label">文章摘要</label>
        <div class="layui-input-block">
            <textarea name="" required lay-verify="required" placeholder="请输入" class="layui-textarea"></textarea>
        </div>
  </div>
</form>

<script>
    let id = '@(ViewData["id"] != null ? ViewData["id"] : 0)';
    let action = '@ViewData["action"]';
</script>

@section Scripts {
    <script src="~/js/admin/post/addOrEdit.js"></script>
}