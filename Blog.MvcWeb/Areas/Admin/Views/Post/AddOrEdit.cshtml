@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/lib/layuiadmin/layui/css/layui.css" media="all" />
    <link rel="stylesheet" href="~/lib/layuiadmin/style/admin.css" media="all" />
    <link rel="stylesheet" href="~/lib/editor.md/css/editormd.css" />
    <style>
        html, body {
            height: auto;
            overflow-y: auto;
            overflow-x: auto;
        }
    </style>
</head>
<body class="layui-layout-body" style="padding: 20px;">

    <form class="layui-form" id="addOrEdit" lay-filter="addOrEdit">
        <input class="d-none" id="blogCategoryId" name="blogCategoryId" />
        <input class="d-none" id="blogPostId" name="blogPostId" />
        <!-- 第一行：标题 -->
        <div class="row align-items-center mb-3 ml-2">
            <label class="col-sm-1 text-start">标题</label>
            <div class="col-sm-11">
                <input type="text" name="title" required lay-verify="required" placeholder="请输入标题" autocomplete="off" class="layui-input">
            </div>
        </div>

        <!-- 第二行：文章简要 -->
        <div class="row align-items-center mb-3 ml-2">
            <label class="col-sm-1 text-start">文章简要</label>
            <div class="col-sm-11">
                <textarea name="summary" required lay-verify="required" placeholder="请输入文章简要" class="layui-textarea" style="height: 100px;"></textarea>
            </div>
        </div>

        <div class="row align-items-center mb-3 ml-2">
            <div class="col-sm-12">
                <div id="content-editormd" name="content" lay-verify="requird" placeholder="请输入文章内容">
                    <textarea style="display:none;"></textarea>
                </div>
            </div>
        </div>

        <div class="row align-items-center mb-3 ml-2">
            <label class="col-sm-1 text-start">分类</label>
            <div class="col-sm-11">
                <input type="text" name="categoryName" id="categorySelect" required
                       lay-verify="required" placeholder="请输入标题"
                       ts-selected=""
                       autocomplete="off" class="layui-input">
            </div>
        </div>

        <div class="row align-items-center mb-3 ml-2">
            <label class="col-sm-1 text-start">标签</label>
            <div class="col-sm-11" id="tagSelect">
            </div>
        </div>

    </form>


</body>
</html>

<script src="~/lib/jquery/dist/jquery.js"></script>
<script src="~/js/jquery-serializeObject.js"></script>
<script src="~/lib/layuiadmin/layui/layui.js"></script>
<script src="~/lib/editor.md/editormd.js"></script>

<!-- 添加LayuiAdmin初始化脚本（关键！） -->
<script src="~/js/admin/layout.js"></script>
<script src="~/js/util.js"></script>
<script src="~/lib/layuiadmin/xm-select.js"></script>
<script src="~/js/admin/post/addOrEdit.js"></script>