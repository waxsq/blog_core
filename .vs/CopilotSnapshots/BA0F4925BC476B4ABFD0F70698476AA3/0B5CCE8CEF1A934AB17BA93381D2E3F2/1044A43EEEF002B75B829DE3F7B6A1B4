using System;
using System.Collections.Generic;
using System.Linq;
using System.Linq.Expressions;
using System.Reflection;
using System.Text;
using System.Threading.Tasks;
using Blog.Core.Interfaces;
using SqlSugar;

namespace Blog.Repository.Commons
{
    /// <summary>
    /// 基于 ISqlSugarClient 的通用仓储实现（示例）
    /// - 依赖注入 ISqlSugarClient
    /// - 提供增删改查、分页查询、以及“以树形参数”为输入的查询示例实现
    /// </summary>
    /// <typeparam name="TEntity">实体类型</typeparam>
    /// <typeparam name="TKey">主键类型</typeparam>
    public class Repository<TEntity, TKey> : IRepository<TEntity, TKey>
        where TEntity : class, new()
    {
        private readonly ISqlSugarClient _db;

        public Repository(ISqlSugarClient db)
        {
            _db = db ?? throw new ArgumentNullException(nameof(db));
        }

        // --- Create ---
        public async Task<int> InsertAsync(TEntity entity)
        {
            if (entity == null) throw new ArgumentNullException(nameof(entity));
            return await _db.Insertable(entity).ExecuteCommandAsync();
        }

        public async Task<int> InsertAsync(IEnumerable<TEntity> entities)
        {
            if (entities == null) throw new ArgumentNullException(nameof(entities));
            var arr = entities as TEntity[] ?? entities.ToArray();
            if (arr.Length == 0) return 0;
            return await _db.Insertable(arr).ExecuteCommandAsync();
        }

        // --- Read ---
        public async Task<TEntity?> GetByIdAsync(TKey id)
        {
            if (id == null) return null!;
            return await _db.Queryable<TEntity>().InSingleAsync(id);
        }

        public async Task<List<TEntity>> GetAllAsync()
        {
            return await _db.Queryable<TEntity>().ToListAsync();
        }

        public async Task<List<TEntity>> QueryAsync(Expression<Func<TEntity, bool>>? predicate = null)
        {
            var query = _db.Queryable<TEntity>();
            if (predicate != null) query = query.Where(predicate);
            return await query.ToListAsync();
        }

        /// <summary>
        /// 分页查询（使用 SqlSugar 的 PageModel）
        /// </summary>
        public async Task<List<TEntity>> QueryPagedAsync(PageModel pageModel,
            Expression<Func<TEntity, bool>>? predicate = null,
            Expression<Func<TEntity, object>>? orderBy = null,
            bool isAsc = true)
        {
            if (pageModel == null) throw new ArgumentNullException(nameof(pageModel));

            var query = _db.Queryable<TEntity>();
            if (predicate != null) query = query.Where(predicate);

            if (orderBy != null)
            {
                // 使用 OrderBy(Expression, OrderByType) 保持与 SqlSugar 的约定
                query = query.OrderBy(orderBy, isAsc ? OrderByType.Asc : OrderByType.Desc);
            }

            // 修复：SqlSugar 的 ToPageListAsync 需要传递 pageIndex, pageSize, RefAsync<int> totalNumber
            RefAsync<int> totalNumber = new RefAsync<int>(pageModel.TotalCount);
            var result = await query.ToPageListAsync(pageModel.PageIndex, pageModel.PageSize, totalNumber);
            pageModel.TotalCount = totalNumber.Value;
            return result;
        }

        /// <summary>
        /// 根据“树形参数”进行查询的示例实现：
        /// - 如果传入的 tree 是 TKey 的集合，按主键 In 查询
        /// - 如果传入的 tree 有名为 Ids 或 IdList 的属性且该属性为 IEnumerable<TKey>，取其值作为 Id 列表进行 In 查询
        /// - 否则回退到仅使用 predicate 查询（需要根据业务在调用处实现更复杂的树查询）
        /// </summary>
        public async Task<List<TEntity>> QueryByTreeAsync<TTree>(TTree tree, Expression<Func<TEntity, bool>>? predicate = null)
        {
            if (tree == null) return await QueryAsync(predicate);

            // 1) 如果 tree 本身就是 TKey 的集合
            if (tree is IEnumerable<TKey> idsEnumerable)
            {
                var q = _db.Queryable<TEntity>().In(idsEnumerable);
                if (predicate != null) q = q.Where(predicate);
                return await q.ToListAsync();
            }

            // 2) 反射查找常见的集合属性（Ids / IdList / IdsList 等）
            var treeType = typeof(TTree);
            var candidateNames = new[] { "Ids", "IdList", "IdsList", "IdsEnumerable" };
            foreach (var name in candidateNames)
            {
                var prop = treeType.GetProperty(name, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
                if (prop == null) continue;
                if (!typeof(System.Collections.IEnumerable).IsAssignableFrom(prop.PropertyType)) continue;

                var value = prop.GetValue(tree);
                if (value is IEnumerable<TKey> idsFromProp)
                {
                    var q = _db.Queryable<TEntity>().In(idsFromProp);
                    if (predicate != null) q = q.Where(predicate);
                    return await q.ToListAsync();
                }
            }

            // 3) 回退：仅根据 predicate 查询（业务方可重写/扩展此方法或在传入的 tree 中放置可识别的 Id 集合）
            return await QueryAsync(predicate);
        }

        // --- Update ---
        public async Task<int> UpdateAsync(TEntity entity)
        {
            if (entity == null) throw new ArgumentNullException(nameof(entity));
            return await _db.Updateable(entity).ExecuteCommandAsync();
        }

        public async Task<int> UpdateAsync(Expression<Func<TEntity, bool>> predicate, Expression<Func<TEntity, TEntity>> updateExpression)
        {
            if (predicate == null) throw new ArgumentNullException(nameof(predicate));
            if (updateExpression == null) throw new ArgumentNullException(nameof(updateExpression));

            return await _db.Updateable<TEntity>()
                            .SetColumns(updateExpression)
                            .Where(predicate)
                            .ExecuteCommandAsync();
        }

        // --- Delete ---
        public async Task<int> DeleteByIdAsync(TKey id)
        {
            if (id == null) throw new ArgumentNullException(nameof(id));
            return await _db.Deleteable<TEntity>().In(id).ExecuteCommandAsync();
        }

        public async Task<int> DeleteAsync(Expression<Func<TEntity, bool>> predicate)
        {
            if (predicate == null) throw new ArgumentNullException(nameof(predicate));
            return await _db.Deleteable<TEntity>().Where(predicate).ExecuteCommandAsync();
        }
    }

    // Provide convenience non-generic base for TKey = long
    public class Repository<TEntity> : Repository<TEntity, long> where TEntity : class, new()
    {
        public Repository(ISqlSugarClient db) : base(db)
        {
        }
    }
}
